      <CodeComponent name="infoCode" plugin="None">
        <Param val="" valType="extendedCode" updates="constant" name="Before Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Before JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="Begin JS Experiment"/>
        <Param val="stage = &quot;id&quot;;&amp;#10;current_text = &quot;&quot;;&amp;#10;entryPrompt.text = &quot;Participant ID:&quot;;&amp;#10;entryText.text = &quot;_&quot;;&amp;#10;infoWarning.opacity = 0;&amp;#10;" valType="extendedCode" updates="constant" name="Begin JS Routine"/>
        <Param val="stage = 'id'&amp;#10;current_text = ''&amp;#10;&amp;#10;entryPrompt.text = 'Participant ID:'&amp;#10;entryText.text = '_'&amp;#10;&amp;#10;infoWarning.opacity = 0" valType="extendedCode" updates="constant" name="Begin Routine"/>
        <Param val="Auto-&gt;JS" valType="str" updates="None" name="Code Type"/>
        <Param val="keys = entryKeys.getKeys(waitRelease=False)&amp;#10;&amp;#10;for key in keys:&amp;#10;    k = key.name&amp;#10;&amp;#10;    if k == 'return':&amp;#10;        if stage == 'id':&amp;#10;            if current_text.strip() != '':&amp;#10;                expInfo['participant_ID'] = current_text.strip()&amp;#10;                stage = 'age'&amp;#10;                current_text = ''&amp;#10;                entryPrompt.text = 'Age:'&amp;#10;                entryText.text = '_'&amp;#10;                infoWarning.opacity = 0&amp;#10;            else:&amp;#10;                infoWarning.text = 'Please enter a participant ID'&amp;#10;                infoWarning.opacity = 1&amp;#10;&amp;#10;        elif stage == 'age':&amp;#10;            if current_text.isdigit():&amp;#10;                expInfo['age'] = current_text&amp;#10;                continueRoutine = False&amp;#10;            else:&amp;#10;                infoWarning.text = 'Please enter a valid numeric age'&amp;#10;                infoWarning.opacity = 1&amp;#10;&amp;#10;    elif k == 'backspace':&amp;#10;        current_text = current_text[:-1]&amp;#10;        entryText.text = current_text + '_'&amp;#10;&amp;#10;    elif k == 'space':&amp;#10;        if stage == 'id':&amp;#10;            current_text += ' '&amp;#10;            entryText.text = current_text + '_'&amp;#10;&amp;#10;    elif len(k) == 1:&amp;#10;        if stage == 'id':&amp;#10;            current_text += k&amp;#10;            entryText.text = current_text + '_'&amp;#10;        elif stage == 'age' and k.isdigit():&amp;#10;            current_text += k&amp;#10;            entryText.text = current_text + '_'" valType="extendedCode" updates="constant" name="Each Frame"/>
        <Param val="keys = entryKeys.getKeys({&quot;waitRelease&quot;: false});&amp;#10;for (var key, _pj_c = 0, _pj_a = keys, _pj_b = _pj_a.length; (_pj_c &lt; _pj_b); _pj_c += 1) {&amp;#10;    key = _pj_a[_pj_c];&amp;#10;    k = key.name;&amp;#10;    if ((k === &quot;return&quot;)) {&amp;#10;        if ((stage === &quot;id&quot;)) {&amp;#10;            if ((current_text.strip() !== &quot;&quot;)) {&amp;#10;                expInfo[&quot;participant_ID&quot;] = current_text.strip();&amp;#10;                stage = &quot;age&quot;;&amp;#10;                current_text = &quot;&quot;;&amp;#10;                entryPrompt.text = &quot;Age:&quot;;&amp;#10;                entryText.text = &quot;_&quot;;&amp;#10;                infoWarning.opacity = 0;&amp;#10;            } else {&amp;#10;                infoWarning.text = &quot;Please enter a participant ID&quot;;&amp;#10;                infoWarning.opacity = 1;&amp;#10;            }&amp;#10;        } else {&amp;#10;            if ((stage === &quot;age&quot;)) {&amp;#10;                if (current_text.isdigit()) {&amp;#10;                    expInfo[&quot;age&quot;] = current_text;&amp;#10;                    continueRoutine = false;&amp;#10;                } else {&amp;#10;                    infoWarning.text = &quot;Please enter a valid numeric age&quot;;&amp;#10;                    infoWarning.opacity = 1;&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;    } else {&amp;#10;        if ((k === &quot;backspace&quot;)) {&amp;#10;            current_text = current_text.slice(0, (- 1));&amp;#10;            entryText.text = (current_text + &quot;_&quot;);&amp;#10;        } else {&amp;#10;            if ((k === &quot;space&quot;)) {&amp;#10;                if ((stage === &quot;id&quot;)) {&amp;#10;                    current_text += &quot; &quot;;&amp;#10;                    entryText.text = (current_text + &quot;_&quot;);&amp;#10;                }&amp;#10;            } else {&amp;#10;                if ((k.length === 1)) {&amp;#10;                    if ((stage === &quot;id&quot;)) {&amp;#10;                        current_text += k;&amp;#10;                        entryText.text = (current_text + &quot;_&quot;);&amp;#10;                    } else {&amp;#10;                        if (((stage === &quot;age&quot;) &amp;&amp; k.isdigit())) {&amp;#10;                            current_text += k;&amp;#10;                            entryText.text = (current_text + &quot;_&quot;);&amp;#10;                        }&amp;#10;                    }&amp;#10;                }&amp;#10;            }&amp;#10;        }&amp;#10;    }&amp;#10;}&amp;#10;" valType="extendedCode" updates="constant" name="Each JS Frame"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Experiment"/>
        <Param val="" valType="extendedCode" updates="constant" name="End JS Routine"/>
        <Param val="" valType="extendedCode" updates="constant" name="End Routine"/>
        <Param val="False" valType="bool" updates="None" name="disabled"/>
