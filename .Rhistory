# image_id (filename only)
if ("image" %in% names(d)) {
d$image_id <- sub(".*/", "", gsub("\\\\", "/", d$image))
} else if ("stim" %in% names(d)) {
d$image_id <- sub(".*/", "", gsub("\\\\", "/", d$stim))
} else if ("filename" %in% names(d)) {
d$image_id <- sub(".*/", "", gsub("\\\\", "/", d$filename))
} else if (!"image_id" %in% names(d)) {
warning(sprintf("No image column in %s; setting image_id = NA", basename(f)))
d$image_id <- NA_character_
}
d <- d %>% mutate(Participant = pid, block = as.character(blk))
all_bdm <- append(all_bdm, list(d))
}
}
bdm <- bind_rows(all_bdm)
if (nrow(bdm) == 0) {
print(skipped)
stop("No usable block1..5 CSVs loaded. See 'skipped' for details.")
}
# core columns present?
if (!"choice"   %in% names(bdm)) stop("No 'choice' column after load.")
if (!"image_id" %in% names(bdm)) stop("No 'image_id' column after load.")
# clean + save
bdm <- bdm %>% filter(!is.na(choice))
dir.create(dirname(out_csv), recursive = TRUE, showWarnings = FALSE)
write.csv(bdm, out_csv, row.names = FALSE)
cat("Saved:", out_csv, "with", nrow(bdm), "rows from", length(unique(bdm$Participant)), "participants\n")
if (nrow(skipped) > 0) {
cat("Skipped files (", nrow(skipped), "):\n", sep = ""); print(skipped)
}
# ---------------- per-image means ± SE ---------------- #
avg_choice <- bdm %>%
group_by(Participant, image_id) %>%
summarise(
Average_Choice = mean(choice, na.rm = TRUE),
SD_Choice      = sd(choice,   na.rm = TRUE),
SE_Choice      = SD_Choice / sqrt(dplyr::n()),
.groups = "drop"
) %>%
arrange(Participant, desc(Average_Choice))
# (optional) quick per-participant plot
for (p in unique(avg_choice$Participant)) {
pd <- avg_choice %>% filter(Participant == p)
g <- ggplot(pd, aes(x = reorder(image_id, -Average_Choice), y = Average_Choice)) +
geom_point(size = 3) +
geom_line(aes(group = 1), alpha = 0.7) +
geom_errorbar(aes(ymin = Average_Choice - SE_Choice,
ymax = Average_Choice + SE_Choice), width = 0.2) +
labs(title = paste("Average Choice Per Image — Participant", p),
x = "Image (ordered)", y = "Average Choice") +
theme_minimal() +
theme(axis.text.x = element_text(angle = 45, hjust = 1))
print(g)
}
# ---------------- wide by block (1..5) ---------------- #
wide <- bdm %>%
pivot_wider(
id_cols     = c(Participant, image_id),
names_from  = block,
values_from = choice,
values_fn   = list(choice = ~mean(.x, na.rm = TRUE))
)
# keep only block columns that exist
blk_cols <- sort(intersect(names(wide), as.character(1:5)))
wide <- wide %>% select(Participant, image_id, all_of(blk_cols))
# rename to Block1..BlockK for clarity
names(wide)[-(1:2)] <- paste0("Block", seq_along(blk_cols))
block_cols <- names(wide)[-(1:2)]
# -------- participant-level average correlation across all block pairs ----- #
participant_correlations <- wide %>%
group_by(Participant) %>%
summarise(
avg_correlation = {
if (length(block_cols) < 2) NA_real_ else {
cm <- cor(select(cur_data(), all_of(block_cols)), use = "pairwise.complete.obs")
ut <- cm[upper.tri(cm)]
if (length(ut)) mean(ut, na.rm = TRUE) else NA_real_
}
},
.groups = "drop"
)
print(participant_correlations)
# ==================== VISUALS FOR ALL 5 BLOCKS ==================== #
# A) SPLOM (scatterplot matrix) across all available blocks (≥2) — per participant
if (length(block_cols) >= 2) {
for (p in unique(wide$Participant)) {
dfp <- wide %>% filter(Participant == p) %>% select(all_of(block_cols)) %>% drop_na()
if (nrow(dfp) == 0) next
dims <- lapply(block_cols, function(col) list(label = col, values = dfp[[col]]))
print(
plot_ly(type = "splom", dimensions = dims,
showupperhalf = FALSE, diagonal = list(visible = TRUE)) %>%
layout(title = paste("Scatter Matrix of Blocks — Participant", p))
)
}
} else {
message("Not enough blocks for a SPLOM (need ≥2).")
}
# B) Correlation heatmap (Block1..Block5) — per participant
for (p in unique(wide$Participant)) {
dfp <- wide %>% filter(Participant == p) %>% select(all_of(block_cols))
if (nrow(dfp) == 0) next
cm <- cor(dfp, use = "pairwise.complete.obs")
cm_long <- as.data.frame(as.table(cm))
colnames(cm_long) <- c("BlockX", "BlockY", "r")
g_heat <- ggplot(cm_long, aes(BlockX, BlockY, fill = r)) +
geom_tile() +
geom_text(aes(label = sprintf("%.2f", r)), size = 3) +
scale_fill_gradient2(limits = c(-1, 1), oob = scales::squish) +
coord_fixed() +
labs(title = paste("Block Correlations — Participant", p),
x = NULL, y = NULL, fill = "r") +
theme_minimal()
print(g_heat)
}
library(dplyr)
library(tidyr)
# ---- 1. reshape to wide (you already do this, but keep it simple here) ---- #
wide <- bdm %>%
group_by(Participant, image_id, block) %>%
summarise(choice = mean(choice, na.rm = TRUE), .groups = "drop") %>%
pivot_wider(names_from = block, values_from = choice)
# keep only block columns
block_cols <- setdiff(names(wide), c("Participant", "image_id"))
# ---- 2. C4: consistency across blocks (correlation) ---- #
c4_scores <- wide %>%
group_by(Participant) %>%
summarise(
C4_consistency = {
if (length(block_cols) < 2) NA_real_ else {
cm <- cor(select(cur_data(), all_of(block_cols)),
use = "pairwise.complete.obs")
mean(cm[upper.tri(cm)], na.rm = TRUE)
}
},
.groups = "drop"
)
# ---- 3. C5: variability in choices ---- #
c5_scores <- bdm %>%
group_by(Participant) %>%
summarise(
C5_variability = sd(choice, na.rm = TRUE),
.groups = "drop"
)
# ---- 4. combine ---- #
quality <- left_join(c4_scores, c5_scores, by = "Participant")
# ---- 5. apply thresholds (EDIT THESE if needed) ---- #
quality <- quality %>%
mutate(
C4_pass = C4_consistency >= 0.3,   # consistency threshold
C5_pass = C5_variability  > 0.5,   # variability threshold
INCLUDE = C4_pass & C5_pass
)
# ---- 6. results ---- #
print(quality)
# optional: who to exclude
excluded <- quality %>% filter(!INCLUDE)
included <- quality %>% filter(INCLUDE)
cat("Included:", nrow(included), "\n")
cat("Excluded:", nrow(excluded), "\n")
View(excluded)
#set up
rm(list=ls())
gc()
