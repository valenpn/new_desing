library(tidyverse)
library(modelsummary)
library(car)
library(stargazer)
library(sandwich)
library(lmtest)
library(readxl)
library(dplyr)
library(dplyr)
#1. SET THE MAIN DIRECTORY WHERE PARTICIPANT FOLDERS ARE LOCATED
main_dir <- "/Users/valentinaparada/Dropbox/LabDropbox/Valentina/Mayas_proyect/data_participants_NC/new"
# 2. LIST ALL PARTICIPANT FOLDERS IN THE MAIN DIRECTORY
participant_folders <- list.dirs(main_dir, recursive = FALSE)
# 3. Initialize the final output list
# This list will store ONE merged data frame per participant (all blocks combined).
participant_merged_data <- list()
# 4. LOOP THROUGH EACH PARTICIPANT FOLDER
for (participant_folder_path in participant_folders) {
# Initialize a temporary list to hold all block data frames for the CURRENT participant
current_participant_blocks <- list()
# Extract Participant ID from the folder name
participant_id <- basename(participant_folder_path)
# 5. GET THE CSV FILES THAT CONTAIN "block" IN THE FILENAME
csv_files <- list.files(
participant_folder_path,
pattern = ".*block.*\\.csv$",
full.names = TRUE,
ignore.case = TRUE
)
# 6. PROCESS BLOCK FILES
if (length(csv_files) > 0) {
for (file in csv_files) {
# Read the CSV file
data <- read_csv(file, show_col_types = FALSE)
# Extract Block Info
block_info <- tools::file_path_sans_ext(basename(file))
# Add Participant and Block info to the data frame
data_processed <- data %>%
mutate(
Participant = participant_id,
BlockInfo = block_info
)
# Store the processed block data frame in the temporary list
current_participant_blocks[[block_info]] <- data_processed
}
# 7. NEW: COMBINE ALL BLOCKS FOR THIS PARTICIPANT INTO ONE DATA FRAME
# bind_rows stacks the data frames vertically.
merged_participant_df <- bind_rows(current_participant_blocks)
# 8. Store the FINAL MERGED data frame into the final output list
participant_merged_data[[participant_id]] <- merged_participant_df
} else {
message(paste("Warning: No 'block' files found for participant:", participant_id))
}
}
# 9. FINAL CHECK: Examine the structure
print("--- Final Output Structure Check ---")
print(paste("Number of participants merged:", length(participant_merged_data)))
# Initialize list to store summary per participant
summary_list <- list()
for (subj in names(participant_merged_data)) {
df <- participant_merged_data[[subj]]
if (!("image_path" %in% names(df)) || !("choice" %in% names(df))) next
df <- df %>% mutate(choice = suppressWarnings(as.numeric(choice)))
summary_df <- df %>%
group_by(image_path) %>%
summarise(
mean_choice = mean(choice, na.rm = TRUE),
sd_choice   = sd(choice,   na.rm = TRUE),
n_trials    = sum(!is.na(choice)),
.groups = "drop"
) %>%
mutate(subject = subj, .before = 1)   # 👈 subject-specific
summary_list[[subj]] <- summary_df
}
print("done")
library(tidyverse)
library(stringr)
# Only remove ../ or ./ at the start and convert \ to /, keep 'stimuli/peanuts.png'
clean_path <- function(x) {
x %>%
as.character() %>%
str_replace_all("\\\\", "/") %>%   # \ -> /
str_replace("^\\.\\./", "") %>%    # remove leading ../
str_replace("^\\./", "") %>%       # remove leading ./
str_trim()
}
# From your existing summary_list (one element per subject)
sd_lookup <- purrr::imap_dfr(
summary_list,
~ .x %>% mutate(subject = .y),   # add subject col from list name
) %>%
mutate(
subject   = as.character(subject),
image_key = clean_path(image_path),   # cleaned path used ONLY as join key
sd_image  = as.numeric(sd_choice)
) %>%
select(subject, image_key, sd_image) %>%
distinct()
# Inspect to see that it looks right:
head(sd_lookup)
main_dir2 <- "/Users/valentinaparada/Dropbox/LabDropbox/Valentina/Mayas_proyect/data_participants_NC/new"
# pattern for your dated files, adjust if needed
date_like_regex <- "^[0-9]{2}-[0-9]{2}-[0-9]{4}_.+\\.csv$"
participant_folders <- list.dirs(main_dir2, recursive = FALSE)
all_subjects_main_with_sds <- list()
for (p_path in participant_folders) {
subject_id <- basename(p_path)   # e.g. "329"
# --- find main (dated) file in this subject folder ---
all_csvs   <- list.files(p_path, pattern="\\.csv$", full.names=TRUE, ignore.case=TRUE)
block_csvs <- list.files(p_path, pattern="block.*\\.csv$", full.names=TRUE, ignore.case=TRUE)
non_block  <- setdiff(all_csvs, block_csvs)
if (length(non_block) == 0) {
message("No main CSV for subject ", subject_id)
next
}
dated <- non_block[grepl(date_like_regex, basename(non_block), ignore.case=TRUE)]
pick  <- if (length(dated) > 0) dated else non_block
main_file <- pick[which.max(file.info(pick)$mtime)]
message("Processing subject ", subject_id, " main file: ", basename(main_file))
main_df <- tryCatch(
readr::read_csv(main_file, show_col_types = FALSE),
error = function(e) { message("Cannot read ", main_file, ": ", e$message); NULL }
)
if (is.null(main_df)) next
# we assume these columns exist in the dated file
need_cols <- c("target1","target2","distractor",
"target1_choice","target2_choice","distractor_choice")
if (!all(need_cols %in% names(main_df))) {
message("Missing required columns in ", basename(main_file), " for subject ", subject_id,
": ", paste(setdiff(need_cols, names(main_df)), collapse=", "))
next
}
# ensure subject column exists and is character
if (!("subject" %in% names(main_df))) {
main_df <- main_df %>% mutate(subject = subject_id)
}
main_df <- main_df %>% mutate(subject = as.character(subject))
# --- create join keys (do NOT overwrite original paths) ---
main_aug <- main_df %>%
mutate(
target1_key    = clean_path(target1),
target2_key    = clean_path(target2),
distractor_key = clean_path(distractor)
)
# --- join SDs for each role: subject × image_key ---
main_aug <- main_aug %>%
left_join(
sd_lookup %>%
rename(target1_key = image_key,
sd_target1  = sd_image),
by = c("subject", "target1_key")
) %>%
left_join(
sd_lookup %>%
rename(target2_key = image_key,
sd_target2  = sd_image),
by = c("subject", "target2_key")
) %>%
left_join(
sd_lookup %>%
rename(distractor_key = image_key,
sd_distractor = sd_image),
by = c("subject", "distractor_key")
)
# optional: coerce the *_choice values to numeric
main_aug <- main_aug %>%
mutate(
target1_choice    = suppressWarnings(as.numeric(target1_choice)),
target2_choice    = suppressWarnings(as.numeric(target2_choice)),
distractor_choice = suppressWarnings(as.numeric(distractor_choice))
)
# store in the big list (keyed by subject)
all_subjects_main_with_sds[[subject_id]] <- main_aug
# optional: also write per-subject file with SDs
out_path <- file.path(p_path,
paste0(tools::file_path_sans_ext(basename(main_file)), "_with_SDs.csv"))
readr::write_csv(main_aug, out_path)
message("  → wrote ", out_path)
}
# --- final combined dataset for all 33 subjects ---
all_subjects_main_with_sds_df <- dplyr::bind_rows(all_subjects_main_with_sds)
# optional: save one big file
# readr::write_csv(all_subjects_main_with_sds_df,
#                  file.path(main_dir, "ALL_subjects_dated_with_SDs.csv"))
# Path where you want to save
out_path <- "/Users/valentinaparada/Dropbox/LabDropbox/Valentina/Mayas_proyect/ALL_subjects_400_SDs.csv"
# Save the combined dataframe
readr::write_csv(all_subjects_main_with_sds_df, out_path)
cat("Saved combined dataset to:\n", out_path, "\n")
#set up
rm(list=ls())
gc()
